# URL base da API do plugin WordPress (sem barra final)
# Desenvolvimento local: http://localhost/wp-json/biju/v1
# Produção: https://sua-loja.com.br/wp-json/biju/v1
VITE_API_URL=http://localhost/wp-json/biju/v1

# Client ID do Google Sign-In (OAuth). Quando definido, o botão "Login com
# Google" é renderizado sem depender da resposta de /auth/google/config do
# backend — garantindo que ele sempre apareça (ex: no checkout).
# Pegue em https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxx.apps.googleusercontent.com
