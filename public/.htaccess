# SPA fallback: qualquer rota desconhecida volta para index.html
# (React Router cuida do roteamento no lado do cliente)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Não reescreve para arquivos reais ou diretórios existentes
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Preserva rotas do WordPress / WooCommerce (API REST, admin, uploads, etc.)
  RewriteCond %{REQUEST_URI} !^/wp-(admin|content|includes|json)
  RewriteCond %{REQUEST_URI} !^/xmlrpc\.php
  RewriteCond %{REQUEST_URI} !^/wp-login\.php

  RewriteRule ^ index.html [L]
</IfModule>

# Cache agressivo para assets com hash (Vite gera hashes no nome)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
